---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Weatherie — Aesthetic Weather & Custom Theme Packs"
	description="Experience weather through art. Choose from curated theme packs like oil paintings and abstract art, or create your own personalized weather experience."
>
	<!-- Decorative Background Elements -->
	<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
		<div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-sky-100/50 blur-[120px]"></div>
		<div class="absolute top-[20%] -right-[10%] w-[30%] h-[50%] rounded-full bg-teal-50/50 blur-[100px]"></div>
		<div class="absolute -bottom-[10%] left-[20%] w-[50%] h-[40%] rounded-full bg-violet-100/30 blur-[120px]"></div>
	</div>

	<main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
		<!-- Floating Navigation -->
		<nav class="py-4 flex justify-between items-center sticky top-0 z-50 bg-white/70 backdrop-blur-xl rounded-2xl px-6 mt-6 border border-white/20 shadow-sm">
			<div class="flex items-center gap-3">
				<div class="w-9 h-9 bg-gradient-to-br from-sky-400 to-teal-400 rounded-lg flex items-center justify-center text-white font-black text-xl shadow-inner">
					W
				</div>
				<span class="text-xl font-extrabold tracking-tight text-slate-800 font-['Outfit'] uppercase">Weatherie</span>
			</div>
			<div class="hidden md:flex gap-10 font-bold text-slate-500 text-sm uppercase tracking-widest">
				<a href="#overview" class="hover:text-sky-500 transition-colors">Overview</a>
				<a href="#themes" class="hover:text-sky-500 transition-colors">Themes</a>
				<a href="#features" class="hover:text-sky-500 transition-colors">Features</a>
			</div>
			<a href="#download" class="bg-slate-900 text-white px-5 py-2 rounded-xl font-bold text-sm hover:bg-slate-800 transition-all active:scale-95 shadow-lg shadow-slate-200">
				Get App
			</a>
		</nav>

		<!-- Immersive Hero -->
		<header class="py-12 md:py-20 text-center space-y-12">
			<div class="space-y-6 max-w-4xl mx-auto">
				<div class="inline-block px-4 py-1.5 rounded-full bg-sky-50 border border-sky-100 text-sky-600 text-xs font-bold uppercase tracking-widest mb-4">
					Redefining the Forecast
				</div>
				<h1 class="text-6xl md:text-8xl font-black text-slate-900 leading-[0.9] font-['Outfit'] tracking-tight">
					Your Weather,<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-sky-500 via-teal-500 to-violet-500">Your Canvas.</span>
				</h1>
				<p class="text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed font-medium">
					Stop looking at boring numbers. Experience the atmosphere through oil paintings, abstract art, and community-crafted theme packs.
				</p>
			</div>

			<div class="relative max-w-4xl mx-auto">
				<!-- Mockup Group -->
				<div class="relative z-10 flex justify-center items-end gap-4 md:gap-8">
					<div class="hidden md:block w-48 h-[400px] bg-white rounded-[2.5rem] shadow-2xl border border-slate-100 -rotate-12 translate-y-12 overflow-hidden opacity-40">
						<div class="h-full bg-gradient-to-b from-orange-100 to-rose-100"></div>
					</div>
                                        <div class="relative group" data-demo-phone-shell>
                                                <!-- High-end Glow -->
                                                <div class="absolute -inset-4 bg-gradient-to-r from-sky-500/20 to-violet-500/20 rounded-[4rem] blur-3xl opacity-50 group-hover:opacity-80 transition-opacity duration-700"></div>
                                                
                                                <!-- Realistic Phone Frame (iPhone 15 Pro style) -->
                                                <div class="relative bg-[#1a1a1a] p-[10px] rounded-[3.5rem] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.5)] border-[1px] border-white/10 ring-1 ring-black ring-inset">
                                                        <!-- Side Buttons -->
                                                        <div class="absolute -left-[2px] top-24 w-[3px] h-12 bg-[#222] rounded-r-sm border-l border-white/5"></div>
                                                        <div class="absolute -left-[2px] top-40 w-[3px] h-12 bg-[#222] rounded-r-sm border-l border-white/5"></div>
                                                        <div class="absolute -right-[2px] top-32 w-[3px] h-20 bg-[#222] rounded-l-sm border-r border-white/5"></div>

                                                        <!-- Inner Bezel -->
                                                        <div class="w-[280px] md:w-[310px] aspect-[9/19.5] bg-black rounded-[2.8rem] overflow-hidden relative shadow-inner ring-1 ring-white/5">
                                                                
                                                                <!-- Dynamic Island -->
                                                                <div class="absolute top-2.5 left-1/2 -translate-x-1/2 w-24 h-6 bg-black rounded-full z-20 flex items-center justify-end px-3 gap-1.5">
                                                                        <div class="w-1 h-1 bg-sky-500/40 rounded-full"></div>
                                                                        <div class="w-2 h-2 bg-[#111] rounded-full ring-1 ring-white/5"></div>
                                                                </div>

                                                                <!-- Screen Content -->
                                                                <div class="w-full h-full relative z-10 overflow-hidden" style="overscroll-behavior: contain;">
                                                                        <div class="absolute inset-0 overflow-hidden">
                                                                                <div class="w-[125%] h-[125%] origin-top-left scale-[0.8]" style="overscroll-behavior: contain;">
                                                                                        <iframe src="/demo/index.html" data-demo-phone-frame data-base-src="/demo/index.html" class="block w-full h-full border-none" style="overscroll-behavior: contain;" allow="geolocation" scrolling="no" title="Weatherie Interactive Demo"></iframe>
                                                                                </div>
                                                                        </div>
                                                                </div>

                                                                <!-- Screen Reflection -->
                                                                <div class="absolute inset-0 pointer-events-none z-30 bg-gradient-to-tr from-transparent via-white/[0.02] to-white/[0.05]"></div>
                                                        </div>
                                                </div>
                                        </div>
					<div class="hidden md:block w-48 h-[400px] bg-white rounded-[2.5rem] shadow-2xl border border-slate-100 rotate-12 translate-y-12 overflow-hidden opacity-40">
						<div class="h-full bg-gradient-to-b from-sky-100 to-violet-100"></div>
					</div>
				</div>
			</div>
		</header>

		<!-- Bento Grid Overview -->
		<section id="overview" class="py-12">
			<div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-6 h-auto md:h-[800px]">
				<!-- Main Large Card -->
				<div class="md:col-span-2 md:row-span-2 bg-white rounded-[3rem] p-10 border border-slate-100 shadow-sm flex flex-col justify-between group overflow-hidden relative">
					<div class="absolute top-0 right-0 w-64 h-64 bg-sky-100 rounded-full blur-[100px] -mr-32 -mt-32 transition-transform group-hover:scale-150"></div>
					<div class="relative z-10">
						<h3 class="text-3xl font-black text-slate-900 font-['Outfit'] mb-4">Curated Art Packs</h3>
						<p class="text-slate-500 font-medium max-w-xs leading-relaxed">Expertly selected color palettes and styles that shift with the time of day and humidity.</p>
					</div>
					<div class="relative z-10 mt-8 aspect-video rounded-2xl bg-slate-900 overflow-hidden shadow-2xl">
						<div class="absolute inset-0 bg-gradient-to-tr from-sky-400 via-teal-400 to-orange-300 opacity-80"></div>
						<div class="absolute inset-0 flex items-center justify-center">
							<span class="text-white font-black text-4xl italic opacity-20">ABSTRACT FLOW</span>
						</div>
					</div>
				</div>

				<!-- Secondary Cards -->
				<div class="md:col-span-2 bg-gradient-to-br from-slate-900 to-slate-800 rounded-[3rem] p-10 text-white flex flex-col justify-between relative overflow-hidden group">
					<div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1579546929518-9e396f3cc809?auto=format&fit=crop&q=80&w=800')] opacity-20 grayscale group-hover:grayscale-0 transition-all duration-700"></div>
					<div class="relative z-10">
						<h3 class="text-3xl font-black font-['Outfit'] mb-2">Import Your Life</h3>
						<p class="text-slate-400 font-medium">Set your own photos as the backdrop for your weather stories.</p>
					</div>
					<button class="relative z-10 self-start px-6 py-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 font-bold text-sm transition-all">
						Learn How
					</button>
				</div>

				<!-- Small Square Cards -->
				<div class="bg-teal-500 rounded-[3rem] p-8 text-white flex flex-col items-center justify-center text-center space-y-4">
					<div class="text-4xl font-bold font-['Outfit']">100+</div>
					<p class="text-sm font-bold uppercase tracking-widest opacity-80 leading-tight">Theme Packs<br/>Available</p>
				</div>

				<div class="bg-white rounded-[3rem] p-8 border border-slate-100 shadow-sm flex flex-col justify-center space-y-4 overflow-hidden group">
					<div class="flex gap-2 mb-2">
						{[1,2,3].map(() => <div class="w-8 h-8 rounded-lg bg-slate-100 group-hover:bg-sky-100 transition-colors"></div>)}
					</div>
					<p class="text-sm font-bold text-slate-800">Community Packages</p>
					<p class="text-xs text-slate-500 font-medium">Shared by creators from over 50 countries.</p>
				</div>
			</div>
		</section>

		<!-- Themes Carousel Section -->
		<section id="themes" class="py-12 overflow-hidden">
			<div class="text-center max-w-3xl mx-auto mb-16 px-4">
				<h2 class="text-4xl font-black text-slate-900 mb-4 font-['Outfit'] uppercase tracking-tight">Featured Theme Packs</h2>
				<p class="text-lg text-slate-500 font-medium">From classic masterpieces to digital abstractions.</p>
			</div>

			<div class="relative">
				<div id="carousel" class="flex overflow-x-auto pb-12 hide-scrollbar snap-x snap-mandatory gap-6 px-4 md:px-[calc(50%-175px)]">
					{
						[
							{ title: "Oil Paintings", desc: "Brush strokes and vibrant pigments for an analog feel.", color: "bg-orange-50", text: "text-orange-900", img: "https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?auto=format&fit=crop&q=80&w=400" },
							{ title: "Abstract Flow", desc: "Fluid gradients that react to wind and humidity levels.", color: "bg-sky-50", text: "text-sky-900", img: "https://images.unsplash.com/photo-1541701494587-cb58502866ab?auto=format&fit=crop&q=80&w=400" },
							{ title: "Midnight Ink", desc: "Deep monochrome textures for night-time serenity.", color: "bg-slate-900", text: "text-white", dark: true, img: "https://images.unsplash.com/photo-1515462277126-2dd0c162007a?auto=format&fit=crop&q=80&w=400" },
							{ title: "Naturalist", desc: "High-contrast nature photography from the wild.", color: "bg-teal-50", text: "text-teal-900", img: "https://images.unsplash.com/photo-1501854140801-50d01698950b?auto=format&fit=crop&q=80&w=400" },
							{ title: "Neo-Impression", desc: "Pointillist weather effects for the modern art lover.", color: "bg-violet-50", text: "text-violet-900", img: "https://images.unsplash.com/photo-1549490349-8643362247b5?auto=format&fit=crop&q=80&w=400" }
						].map((item) => (
							<div class="carousel-item min-w-[300px] md:min-w-[400px] snap-center transition-all duration-500 will-change-transform">
								<div class={`${item.color} rounded-[3rem] overflow-hidden border ${item.dark ? 'border-slate-800' : 'border-slate-100'} shadow-xl h-full flex flex-col`}>
									<div class="h-64 overflow-hidden">
										<img src={item.img} alt={item.title} class="w-full h-full object-cover" />
									</div>
									<div class="p-8">
										<h3 class={`text-2xl font-black mb-2 font-['Outfit'] ${item.text}`}>{item.title}</h3>
										<p class={`${item.dark ? 'text-slate-400' : 'text-slate-600'} text-sm font-medium`}>{item.desc}</p>
									</div>
								</div>
							</div>
						))
					}
				</div>

				<div class="flex justify-center gap-4 mt-4 text-slate-300 pointer-events-none">
					<svg class="w-6 h-6 animate-bounce-x-left" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
					<span class="text-xs font-black uppercase tracking-[0.3em]">Swipe Themes</span>
					<svg class="w-6 h-6 animate-bounce-x-right" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
				</div>
			</div>
		</section>

		<!-- Features Restructured Grid -->
		<section id="features" class="py-12 border-t border-slate-100">
			<div class="max-w-4xl mb-12">
				<h2 class="text-4xl font-black text-slate-900 font-['Outfit'] leading-tight mb-4 uppercase">Beyond Just a Pretty Interface</h2>
				<p class="text-slate-500 font-medium leading-relaxed">High-performance weather tools for the data-driven enthusiast.</p>
			</div>

			<div class="space-y-12">
				{[
					{ 
						title: "Dynamic Radar", 
						desc: "Real-time precipitation maps with a stylized, artistic overlay. Track storms across a canvas of high-resolution data.", 
						visual: "bg-sky-500/20"
					},
					{ 
						title: "Hourly Nuance", 
						desc: "Detailed breakdown of wind, UV index, and air quality. Every metric is visualised to match your selected theme.", 
						visual: "bg-teal-500/20"
					},
					{ 
						title: "Theme Editor", 
						desc: "Create your own packs with our intuitive color-mapping engine. Share your unique vision with the global community.", 
						visual: "bg-violet-500/20"
					}
				].map((feature) => (
					<div class="grid grid-cols-1 md:grid-cols-[1fr_400px] gap-x-16 gap-y-6 items-start border-b border-slate-50 pb-12 last:border-0 last:pb-0">
						<h4 class="order-1 md:col-start-1 md:row-start-1 text-2xl font-black text-slate-800 font-['Outfit'] uppercase tracking-tight">
							{feature.title}
						</h4>

						<div class="order-2 md:col-start-2 md:row-start-1 md:row-span-2">
							<div class={`h-56 md:h-64 rounded-[2.5rem] ${feature.visual} border-2 border-dashed border-slate-200 flex items-center justify-center overflow-hidden relative group`}>
								<div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
								<span class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400">Visual Component</span>
							</div>
						</div>

						<p class="order-3 md:col-start-1 md:row-start-2 text-slate-500 font-medium leading-relaxed text-lg">
							{feature.desc}
						</p>
					</div>
				))}
			</div>
		</section>

		<!-- CTA -->
		<section id="download" class="py-12">
			<div class="bg-gradient-to-tr from-sky-600 via-sky-500 to-teal-400 rounded-[4rem] p-12 md:p-20 text-center text-white relative overflow-hidden shadow-2xl shadow-sky-200">
				<div class="absolute inset-0 opacity-20 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
				
				<div class="relative z-10 max-w-2xl mx-auto space-y-10">
					<h2 class="text-4xl md:text-6xl font-black font-['Outfit'] leading-tight italic">Ready to see the weather differently?</h2>
					
					<div class="flex flex-col gap-8 items-center">
						<div class="flex flex-wrap gap-4 justify-center">
							<a href="#" class="bg-black text-white w-56 py-4 rounded-2xl flex items-center justify-center gap-4 transition-all hover:scale-105 hover:shadow-xl active:scale-95 border border-white/10">
								<svg class="w-8 h-8" viewBox="0 0 384 512" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-48.7-19.1-77.5-19.1-36.9 0-76.3 24.6-94.6 61.4-41 82.3-18.8 182.7 21.2 244.3 23.3 33.9 55 67.4 96.6 67.4 34.1 0 44-19.1 85.6-19.1 41.7 0 52.2 19.1 85.7 19.1 43.1 0 73.3-33.8 96-67.4 15.8-23.9 20.6-34.4 30.8-53-73.1-28.6-81.8-119.2-80.6-129.7zm-60.9-174.5c20-24.2 33.4-57.8 29.7-91.2-28.1 1.1-62.2 18.8-82.3 42.4-18 20.8-33.7 54.8-29.6 87.3 31.1 2.4 62.2-14.3 82.2-38.5z"/></svg>
								<div class="text-left">
									<div class="text-[10px] uppercase font-bold opacity-70 leading-none">Download on the</div>
									<div class="text-xl font-bold leading-none mt-1">App Store</div>
								</div>
							</a>
							
							<a href="#" class="bg-black text-white w-56 py-4 rounded-2xl flex items-center justify-center gap-4 transition-all hover:scale-105 hover:shadow-xl active:scale-95 border border-white/10">
								<svg class="w-8 h-8" viewBox="0 0 512 512" fill="currentColor"><path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256.6-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-10.3 18-28.5-1.2-40.8zM325.3 277.7l60.1 60.1L104.6 499l220.7-221.3z"/></svg>
								<div class="text-left">
									<div class="text-[10px] uppercase font-bold opacity-70 leading-none">Get it on</div>
									<div class="text-xl font-bold leading-none mt-1">Google Play</div>
								</div>
							</a>
						</div>

						<a href="#themes" class="text-white/80 hover:text-white font-black text-lg underline underline-offset-8 transition-all">
							Explore Themes
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="py-12 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center gap-8">
			<div class="flex items-center gap-3">
				<div class="w-6 h-6 bg-slate-900 rounded-md flex items-center justify-center text-white font-black text-xs">W</div>
				<span class="font-black text-slate-800 uppercase tracking-tighter">Weatherie</span>
			</div>
			<div class="flex gap-10 text-xs font-black text-slate-400 uppercase tracking-widest">
				<a href="/privacy" class="hover:text-sky-500 transition-colors">Privacy</a>
				<a href="/terms" class="hover:text-sky-500 transition-colors">Terms</a>
				<a href="mailto:support@weatherie.com" class="hover:text-sky-500 transition-colors">Support</a>
			</div>
			<div class="text-slate-400 text-[10px] font-bold uppercase tracking-[0.2em]">
				© {new Date().getFullYear()} Weatherie.
			</div>
		</footer>
	</main>
</Layout>

<script>
	const carousel = document.getElementById('carousel');
	if (carousel) {
		carousel.addEventListener('scroll', () => {
			const scrollLeft = carousel.scrollLeft;
			const carouselCenter = scrollLeft + carousel.clientWidth / 2;
			
			Array.from(carousel.children).forEach((child) => {
				const card = child as HTMLElement;
				const cardCenter = card.offsetLeft + card.clientWidth / 2;
				const distanceFromCenter = Math.abs(carouselCenter - cardCenter);
				const scale = Math.max(0.9, 1 - (distanceFromCenter / 1200));
				const opacity = Math.max(0.7, 1 - (distanceFromCenter / 2000));
				card.style.transform = `scale(${scale})`;
				card.style.opacity = opacity.toString();
			});
		});
		carousel.dispatchEvent(new Event('scroll'));
	}

	const demoPhoneShell = document.querySelector('[data-demo-phone-shell]');
	const demoPhoneFrame = document.querySelector('[data-demo-phone-frame]');
	if (demoPhoneShell && demoPhoneFrame instanceof HTMLIFrameElement) {
		const root = document.documentElement;
		const body = document.body;
		const demoFrameOrigin = new URL(
			demoPhoneFrame.dataset.baseSrc || demoPhoneFrame.getAttribute('src') || '/demo/index.html',
			window.location.origin,
		).origin;
		let isScrollLocked = false;
		let unlockTimer = 0;
		let previousRootOverscroll = '';
		let previousBodyOverflow = '';
		let previousBodyTouchAction = '';

		const lockPageScroll = () => {
			window.clearTimeout(unlockTimer);
			if (!isScrollLocked) {
				previousRootOverscroll = root.style.overscrollBehavior;
				previousBodyOverflow = body.style.overflow;
				previousBodyTouchAction = body.style.touchAction;
				root.style.overscrollBehavior = 'none';
				body.style.overflow = 'hidden';
				body.style.touchAction = 'none';
				isScrollLocked = true;
			}
		};

		const unlockPageScroll = () => {
			window.clearTimeout(unlockTimer);
			if (isScrollLocked) {
				root.style.overscrollBehavior = previousRootOverscroll;
				body.style.overflow = previousBodyOverflow;
				body.style.touchAction = previousBodyTouchAction;
				isScrollLocked = false;
			}
		};

		const scheduleUnlock = (delay = 140) => {
			window.clearTimeout(unlockTimer);
			unlockTimer = window.setTimeout(unlockPageScroll, delay);
		};

		demoPhoneShell.addEventListener(
			'wheel',
			(event) => {
				lockPageScroll();
				event.preventDefault();
				scheduleUnlock(180);
			},
			{ passive: false },
		);
		demoPhoneShell.addEventListener('pointerdown', lockPageScroll, { passive: true });
		demoPhoneShell.addEventListener('pointerleave', () => scheduleUnlock(0));
		window.addEventListener(
			'message',
			(event) => {
				if (event.origin !== demoFrameOrigin) return;
				if (!event.data || event.data.source !== 'weatherie-demo') return;
				if (event.data.type === 'interaction-start') {
					lockPageScroll();
				}
				if (event.data.type === 'interaction-end') {
					scheduleUnlock(140);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'pointerup',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'touchend',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'touchcancel',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'pagehide',
			() => {
				if (isScrollLocked) {
					unlockPageScroll();
				}
			},
			{ passive: true },
		);
		document.addEventListener(
			'visibilitychange',
			() => {
				if (document.visibilityState !== 'visible' && isScrollLocked) {
					unlockPageScroll();
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'blur',
			() => {
				if (document.activeElement === demoPhoneFrame) {
					lockPageScroll();
				} else if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'focus',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(80);
				}
			},
			{ passive: true },
		);
	}

	if (demoPhoneFrame instanceof HTMLIFrameElement) {
		const baseSrc = demoPhoneFrame.dataset.baseSrc || demoPhoneFrame.getAttribute('src') || '/demo/index.html';
		const cacheKey = 'weatherie-demo-location';

		const applyLocationToFrame = (location) => {
			const url = new URL(baseSrc, window.location.origin);
			if (location?.latitude != null && location?.longitude != null) {
				url.searchParams.set('lat', String(location.latitude));
				url.searchParams.set('lon', String(location.longitude));
				if (location.city) url.searchParams.set('city', location.city);
				if (location.country) url.searchParams.set('country', location.country);
			}
			const nextSrc = `${url.pathname}${url.search}`;
			if (demoPhoneFrame.getAttribute('src') !== nextSrc) {
				demoPhoneFrame.setAttribute('src', nextSrc);
			}
		};

		const loadCachedLocation = () => {
			try {
				const cached = sessionStorage.getItem(cacheKey);
				if (!cached) return null;
				return JSON.parse(cached);
			} catch {
				return null;
			}
		};

		const saveCachedLocation = (location) => {
			try {
				sessionStorage.setItem(cacheKey, JSON.stringify(location));
			} catch {}
		};

		const fetchApproximateLocation = async () => {
			try {
				const response = await fetch('https://ipapi.co/json/');
				if (!response.ok) return null;
				const json = await response.json();
				const latitude = Number(json.latitude);
				const longitude = Number(json.longitude);
				if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) return null;
				return {
					latitude,
					longitude,
					city: (json.city && String(json.city).trim()) || 'Current Location',
					country: (json.country_code && String(json.country_code).toUpperCase()) || '',
				};
			} catch {
				return null;
			}
		};

		const cachedLocation = loadCachedLocation();
		if (cachedLocation) {
			applyLocationToFrame(cachedLocation);
		}

		if (navigator.geolocation) {
			navigator.geolocation.getCurrentPosition(
				async (position) => {
					const location = {
						latitude: position.coords.latitude,
						longitude: position.coords.longitude,
						city: 'Current Location',
						country: '',
					};

					try {
						const response = await fetch(
							`https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${position.coords.latitude}&longitude=${position.coords.longitude}&localityLanguage=en`,
						);
						if (response.ok) {
							const json = await response.json();
							location.city =
								(json.city && String(json.city).trim()) ||
								(json.locality && String(json.locality).trim()) ||
								(json.principalSubdivision && String(json.principalSubdivision).trim()) ||
								location.city;
							location.country = (json.countryCode && String(json.countryCode).toUpperCase()) || '';
						}
					} catch {}

					saveCachedLocation(location);
					applyLocationToFrame(location);
				},
				async () => {
					const fallbackLocation = await fetchApproximateLocation();
					if (fallbackLocation) {
						saveCachedLocation(fallbackLocation);
						applyLocationToFrame(fallbackLocation);
					}
				},
				{
					enableHighAccuracy: true,
					timeout: 5000,
					maximumAge: 600000,
				},
			);
		} else {
			fetchApproximateLocation().then((fallbackLocation) => {
				if (fallbackLocation) {
					saveCachedLocation(fallbackLocation);
					applyLocationToFrame(fallbackLocation);
				}
			});
		}
	}
</script>

<style>
	html {
		scroll-behavior: smooth;
		scrollbar-gutter: stable both-edges;
	}
	@keyframes pulse {
		0%, 100% { opacity: 0.6; transform: scale(1); }
		50% { opacity: 0.4; transform: scale(1.1); }
	}
	.animate-pulse {
		animation: pulse 8s ease-in-out infinite;
	}
	.hide-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.hide-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	@keyframes bounce-x-left {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(-5px); }
	}
	@keyframes bounce-x-right {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(5px); }
	}
	.animate-bounce-x-left {
		animation: bounce-x-left 1.5s infinite;
	}
	.animate-bounce-x-right {
		animation: bounce-x-right 1.5s infinite;
	}
</style>
