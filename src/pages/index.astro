---
import Layout from '../layouts/Layout.astro';

const openWeatherApiKey = (
	import.meta.env.OPENWEATHERMAP_API_KEY ??
	import.meta.env.PUBLIC_OPENWEATHERMAP_API_KEY ??
	''
).trim();

const buildDemoSrc = (params = {}) => {
	const url = new URL('https://weatherie.local/demo/index.html');
	for (const [key, value] of Object.entries(params)) {
		if (value != null && String(value).trim() !== '') {
			url.searchParams.set(key, String(value));
		}
	}
	if (openWeatherApiKey) {
		url.searchParams.set('owmKey', openWeatherApiKey);
	}
	return `${url.pathname}${url.search}`;
};

const fullDemoSrc = buildDemoSrc();
const hourlyDemoSrc = buildDemoSrc({
	scene: 'hourly',
	renderer: 'canvaskit',
	v: '20260314d',
});
---

