---
import Layout from '../layouts/Layout.astro';

const openWeatherApiKey = (
	import.meta.env.OPENWEATHERMAP_API_KEY ??
	import.meta.env.PUBLIC_OPENWEATHERMAP_API_KEY ??
	''
).trim();

const buildDemoSrc = (params = {}) => {
	const url = new URL('https://weatherie.local/demo/index.html');
	for (const [key, value] of Object.entries(params)) {
		if (value != null && String(value).trim() !== '') {
			url.searchParams.set(key, String(value));
		}
	}
	if (openWeatherApiKey) {
		url.searchParams.set('owmKey', openWeatherApiKey);
	}
	return `${url.pathname}${url.search}`;
};

const fullDemoSrc = buildDemoSrc();
const hourlyDemoSrc = buildDemoSrc({
	scene: 'hourly',
	renderer: 'canvaskit',
	v: '20260314d',
});
---

<Layout
	title="Weatherie — Aesthetic Weather & Custom Theme Packs"
	description="Experience weather through art. Choose from curated theme packs like oil paintings and abstract art, or create your own personalized weather experience."
>
	<!-- Decorative Background Elements -->
	<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
		<div class="absolute -top-[10%] -left-[10%] h-[40%] w-[40%] rounded-full bg-sky-500/14 blur-[140px]"></div>
