								</div>
							</div>
							<div class="relative flex items-start justify-center lg:justify-end">
								<div class="absolute -inset-6 rounded-[3rem] bg-gradient-to-br from-sky-500/20 via-teal-400/15 to-transparent blur-3xl"></div>
