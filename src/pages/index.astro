<script>
	const carousel = document.getElementById('carousel');
	if (carousel) {
		carousel.addEventListener('scroll', () => {
			const scrollLeft = carousel.scrollLeft;
			const carouselCenter = scrollLeft + carousel.clientWidth / 2;

			Array.from(carousel.children).forEach((child) => {
				const card = child as HTMLElement;
				const cardCenter = card.offsetLeft + card.clientWidth / 2;
				const distanceFromCenter = Math.abs(carouselCenter - cardCenter);
				const scale = Math.max(0.9, 1 - (distanceFromCenter / 1200));
				const opacity = Math.max(0.7, 1 - (distanceFromCenter / 2000));
				card.style.transform = `scale(${scale})`;
				card.style.opacity = opacity.toString();
			});
		});
		carousel.dispatchEvent(new Event('scroll'));
	}

	const demoPhoneShell = document.querySelector('[data-demo-phone-shell]');
	const demoPhoneFrame = document.querySelector('[data-demo-phone-frame]');
	const hourlyPreviewFrame = document.querySelector('[data-demo-hourly-frame]');
	const demoFrames = Array.from(document.querySelectorAll('[data-demo-frame]')).filter(
		(frame): frame is HTMLIFrameElement => frame instanceof HTMLIFrameElement,
	);

	if (demoPhoneShell && demoPhoneFrame instanceof HTMLIFrameElement) {
		const root = document.documentElement;
		const body = document.body;
		const demoFrameOrigin = new URL(
			demoPhoneFrame.dataset.baseSrc || demoPhoneFrame.getAttribute('src') || '/demo/index.html',
			window.location.origin,
		).origin;
		let isScrollLocked = false;
		let unlockTimer = 0;
		let previousRootOverscroll = '';
		let previousBodyOverflow = '';
		let previousBodyTouchAction = '';

		const lockPageScroll = () => {
			window.clearTimeout(unlockTimer);
			if (!isScrollLocked) {
				previousRootOverscroll = root.style.overscrollBehavior;
				previousBodyOverflow = body.style.overflow;
				previousBodyTouchAction = body.style.touchAction;
				root.style.overscrollBehavior = 'none';
				body.style.overflow = 'hidden';
				body.style.touchAction = 'none';
				isScrollLocked = true;
			}
		};

		const unlockPageScroll = () => {
			window.clearTimeout(unlockTimer);
			if (isScrollLocked) {
				root.style.overscrollBehavior = previousRootOverscroll;
				body.style.overflow = previousBodyOverflow;
				body.style.touchAction = previousBodyTouchAction;
				isScrollLocked = false;
			}
		};

		const scheduleUnlock = (delay = 140) => {
			window.clearTimeout(unlockTimer);
			unlockTimer = window.setTimeout(unlockPageScroll, delay);
		};

		demoPhoneShell.addEventListener(
			'wheel',
			(event) => {
				lockPageScroll();
				event.preventDefault();
				scheduleUnlock(180);
			},
			{ passive: false },
		);
		demoPhoneShell.addEventListener('pointerdown', lockPageScroll, { passive: true });
		demoPhoneShell.addEventListener('pointerleave', () => scheduleUnlock(0));
		window.addEventListener(
			'message',
			(event) => {
				if (event.origin !== demoFrameOrigin) return;
				if (!event.data || event.data.source !== 'weatherie-demo') return;
				if (
					event.data.type === 'content-height' &&
					hourlyPreviewFrame instanceof HTMLIFrameElement
				) {
					const nextHeight = Number(event.data.height);
					if (Number.isFinite(nextHeight) && nextHeight > 0) {
						hourlyPreviewFrame.style.height = `${Math.ceil(nextHeight)}px`;
					}
				}
				if (event.data.type === 'interaction-start') {
					lockPageScroll();
				}
				if (event.data.type === 'interaction-end') {
					scheduleUnlock(140);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'pointerup',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'touchend',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'touchcancel',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'pagehide',
			() => {
				if (isScrollLocked) {
					unlockPageScroll();
				}
			},
			{ passive: true },
		);
		document.addEventListener(
			'visibilitychange',
			() => {
				if (document.visibilityState !== 'visible' && isScrollLocked) {
					unlockPageScroll();
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'blur',
			() => {
				if (document.activeElement === demoPhoneFrame) {
					lockPageScroll();
				} else if (isScrollLocked) {
					scheduleUnlock(120);
				}
			},
			{ passive: true },
		);
		window.addEventListener(
			'focus',
			() => {
				if (isScrollLocked) {
					scheduleUnlock(80);
				}
			},
			{ passive: true },
		);
	}

	if (demoFrames.length > 0) {
		const cacheKey = 'weatherie-demo-location';

		const applyLocationToFrames = (location) => {
			demoFrames.forEach((frame) => {
				const baseSrc = frame.dataset.baseSrc || frame.getAttribute('src') || '/demo/index.html';
				const url = new URL(baseSrc, window.location.origin);
				if (location?.latitude != null && location?.longitude != null) {
					url.searchParams.set('lat', String(location.latitude));
					url.searchParams.set('lon', String(location.longitude));
					if (location.city) url.searchParams.set('city', location.city);
					if (location.country) url.searchParams.set('country', location.country);
				}
				const nextSrc = `${url.pathname}${url.search}`;
				if (frame.getAttribute('src') !== nextSrc) {
					frame.setAttribute('src', nextSrc);
				}
			});
		};

		const loadCachedLocation = () => {
			try {
				const cached = sessionStorage.getItem(cacheKey);
				if (!cached) return null;
				return JSON.parse(cached);
			} catch {
				return null;
			}
		};

		const saveCachedLocation = (location) => {
			try {
				sessionStorage.setItem(cacheKey, JSON.stringify(location));
			} catch {}
		};

		const fetchApproximateLocation = async () => {
			try {
				const response = await fetch('https://ipapi.co/json/');
				if (!response.ok) return null;
				const json = await response.json();
				const latitude = Number(json.latitude);
				const longitude = Number(json.longitude);
				if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) return null;
				return {
					latitude,
					longitude,
					city: (json.city && String(json.city).trim()) || 'Current Location',
					country: (json.country_code && String(json.country_code).toUpperCase()) || '',
				};
			} catch {
				return null;
			}
		};

		const cachedLocation = loadCachedLocation();
		if (cachedLocation) {
			applyLocationToFrames(cachedLocation);
		}

		if (navigator.geolocation) {
			navigator.geolocation.getCurrentPosition(
				async (position) => {
					const location = {
						latitude: position.coords.latitude,
						longitude: position.coords.longitude,
						city: 'Current Location',
						country: '',
					};

					try {
						const response = await fetch(
							`https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${position.coords.latitude}&longitude=${position.coords.longitude}&localityLanguage=en`,
						);
						if (response.ok) {
							const json = await response.json();
							location.city =
								(json.city && String(json.city).trim()) ||
								(json.locality && String(json.locality).trim()) ||
								(json.principalSubdivision && String(json.principalSubdivision).trim()) ||
								location.city;
							location.country = (json.countryCode && String(json.countryCode).toUpperCase()) || '';
						}
					} catch {}

					saveCachedLocation(location);
					applyLocationToFrames(location);
				},
				async () => {
					const fallbackLocation = await fetchApproximateLocation();
					if (fallbackLocation) {
						saveCachedLocation(fallbackLocation);
						applyLocationToFrames(fallbackLocation);
					}
				},
				{
					enableHighAccuracy: true,
					timeout: 5000,
					maximumAge: 600000,
				},
			);
		} else {
			fetchApproximateLocation().then((fallbackLocation) => {
				if (fallbackLocation) {
					saveCachedLocation(fallbackLocation);
					applyLocationToFrames(fallbackLocation);
				}
			});
		}
	}
</script>

<style>
	html {
		scroll-behavior: smooth;
		scrollbar-gutter: stable both-edges;
	}
	@keyframes pulse {
		0%, 100% { opacity: 0.6; transform: scale(1); }
		50% { opacity: 0.4; transform: scale(1.1); }
	}
	.animate-pulse {
		animation: pulse 8s ease-in-out infinite;
	}
	.hide-scrollbar::-webkit-scrollbar {
		display: none;
	}
	.hide-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	@keyframes bounce-x-left {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(-5px); }
	}
	@keyframes bounce-x-right {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(5px); }
	}
	.animate-bounce-x-left {
		animation: bounce-x-left 1.5s infinite;
	}
	.animate-bounce-x-right {
		animation: bounce-x-right 1.5s infinite;
	}
</style>
